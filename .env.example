
# LLM via Groq (cognee CUSTOM provider -> LiteLLM groq route). No LLM_ENDPOINT
# needed: the groq/ model prefix lets LiteLLM use Groq's default base URL.
LLM_PROVIDER="custom"
LLM_MODEL="groq/llama-3.3-70b-versatile"
LLM_API_KEY=""

# Embeddings run locally via fastembed (no API key, no rate limits, offline).
# Gemini's free-tier embedding quota (per-day) was too small for real-repo
# ingestion; Groq/xAI offer no embeddings. bge-small-en-v1.5 is 384-dim.
EMBEDDING_PROVIDER="fastembed"
EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"
EMBEDDING_DIMENSIONS=384

COGNEE_SKIP_CONNECTION_TEST=true
GITHUB_TOKEN=""
