# ======================================================================
# Relic .gitignore
# ======================================================================

# --- PRD / internal docs (do not publish) -----------------------------
prd.md
PRD.md
relic_prd.md
*_prd.md
*.prd.md

# --- Secrets / env ----------------------------------------------------
.env
.env.*
!.env.example

# --- Python -----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
wheels/
.installed.cfg

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.cache/

# --- Cognee local data / model & vector caches ------------------------
.cognee/
.cognee_system/
.cognee_cache/
cognee_data/
*.db
*.sqlite
*.sqlite3

# fastembed / HF model downloads (if cached into the repo)
.fastembed_cache/
models/

# --- Node / frontend --------------------------------------------------
node_modules/
.vite/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Installers / binaries --------------------------------------------
*.exe
Claude Setup.exe

# --- Logs -------------------------------------------------------------
*.log
logs/

# --- Editor / OS ------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini
